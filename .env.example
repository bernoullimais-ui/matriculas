# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: A URL pública de produção deste app (sem barra no final).
# Exemplo: https://matriculas.sportforkids.com.br
# Encontre no painel do Vercel → seu projeto → Settings → Domains
APP_URL="https://seu-dominio.vercel.app"

# ─── Admin Panel Auth ─────────────────────────────────────────────────────────
# Credenciais de acesso ao painel administrativo da Matrícula Online.
# Defina valores fortes — estas variáveis substituem o login hardcoded.
ADMIN_USERNAME="seu_usuario_admin"
ADMIN_PASSWORD="sua_senha_forte_aqui"
# Chave secreta para assinar os tokens de sessão admin (qualquer string longa e aleatória).
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_JWT_SECRET="gere_uma_chave_aleatoria_aqui"

# SUPABASE_URL: Your Supabase Project URL
SUPABASE_URL="https://your-project.supabase.co"

# SUPABASE_ANON_KEY: Your Supabase Anon/Public Key
SUPABASE_ANON_KEY="your-anon-key"

# Umbler Utalk Configuration
UTALK_TOKEN=
UTALK_FROM_PHONE=
UTALK_ORGANIZATION_ID=
UTALK_URL=https://app-utalk.umbler.com/api/v1/messages/simplified/

# Brevo Email Configuration
BREVO_API_KEY=

# Pagar.me Configuration
PAGARME_SECRET_KEY=
PAGARME_PUBLIC_KEY=
